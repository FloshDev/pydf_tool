#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
PDF_TOOL_BOOTSTRAP_SCRIPT="$0" exec "$SCRIPT_DIR/python3" -c '
from __future__ import annotations

import json
import os
import sys
from pathlib import Path
from urllib.parse import unquote, urlparse


def _source_path_from_direct_url() -> str | None:
    try:
        from importlib import metadata

        dist = metadata.distribution("pydf-tool")
        raw_metadata = dist.read_text("direct_url.json")
        if not raw_metadata:
            return None

        direct_url = json.loads(raw_metadata)
        parsed = urlparse(direct_url.get("url", ""))
        if parsed.scheme != "file":
            return None

        root_path = Path(unquote(parsed.path))
        if sys.platform.startswith("win") and root_path.as_posix().startswith("/"):
            root_path = Path(root_path.as_posix().lstrip("/"))

        source_path = root_path / "src"
        return str(source_path) if source_path.exists() else None
    except Exception:
        return None


def _source_path_from_ancestors() -> str | None:
    script_hint = Path(os.environ.get("PDF_TOOL_BOOTSTRAP_SCRIPT", "")).resolve()
    if not script_hint.exists():
        return None

    for parent in (script_hint.parent, *script_hint.parents):
        source_path = parent / "src"
        if (parent / "pyproject.toml").exists() and (source_path / "pdf_tool").is_dir():
            return str(source_path)
    return None


def _ensure_source_path() -> None:
    for candidate in (_source_path_from_direct_url(), _source_path_from_ancestors()):
        if candidate and candidate not in sys.path:
            sys.path.insert(0, candidate)
            return


def _load_main():
    try:
        from pdf_tool.cli import main

        return main
    except ModuleNotFoundError as exc:
        if exc.name not in {"pdf_tool", "pdf_tool.cli"}:
            raise

    _ensure_source_path()
    from pdf_tool.cli import main

    return main


if __name__ == "__main__":
    raise SystemExit(_load_main()())
' "$@"
