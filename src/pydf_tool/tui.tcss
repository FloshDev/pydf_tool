/* Variabili colore — palette CLAUDE.md */
$accent: #E8B84B;
$text: #D4D4D4;
$secondary: #7A7A7A;
$border: #3A3A3A;
$error: #E85B4B;
$success: #4BE87A;
$surface: #1A1A1A;
$surface-soft: #202020;
$surface-accent: #2B2416;

/* Nessun background esplicito — sfondo sempre trasparente */

Screen {
    color: $text;
}

#header {
    color: $accent;
    border: solid $border;
    padding: 1 2;
    height: auto;
    text-style: bold;
}

#footer-bar {
    color: $secondary;
    border-top: solid $border;
    padding: 0 2;
    height: auto;
}

ListView {
    border: solid $border;
    background: $surface;
}

ListView > ListItem {
    color: $text;
    background: $surface-soft;
    border: solid $border;
    padding: 1 2;
    margin: 0 0 1 0;
    min-height: 5;
}

ListView > ListItem.--highlight {
    color: $accent;
    background: $surface-accent;
    border: solid $accent;
}

#body {
    height: 1fr;
    margin-top: 1;
}

#menu-panel {
    width: 40;
    border: solid $border;
    padding: 1 1 0 1;
}

#menu-list {
    width: 1fr;
    height: 1fr;
    border: solid $border;
    background: $surface;
}

#menu-list:focus {
    border: solid $accent;
}

#preview-panel {
    width: 1fr;
    height: 1fr;
    border: solid $border;
    padding: 1 2;
    background: $surface;
}

.panel-title {
    color: $accent;
    text-style: bold;
    padding: 0 1 1 1;
}

.menu-item-title {
    color: $text;
    text-style: bold;
}

.menu-item-summary {
    color: $secondary;
    margin-top: 1;
}

ListView > ListItem.--highlight .menu-item-title {
    color: $accent;
}

ListView > ListItem.--highlight .menu-item-summary {
    color: $text;
}

#preview-title {
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
}

#preview-body {
    color: $text;
    height: 1fr;
}

#preview-hint {
    color: $secondary;
    border-top: solid $border;
    padding-top: 1;
}

.step-indicator {
    color: $secondary;
    padding: 0 2;
}

.step-indicator .active {
    color: $accent;
    text-style: bold;
}

.error-label {
    color: $error;
    padding: 0 2;
    height: 1;
}

.success-label {
    color: $success;
}

ProgressBar Bar {
    color: $accent;
    background: $border;
}

Button {
    border: solid $border;
    background: $surface-soft;
    color: $text;
    margin: 1 1 0 1;
    width: auto;
}

Button:focus {
    color: $accent;
    border: solid $accent;
    background: $surface-accent;
}

#btn-run-ocr {
    background: $accent;
    color: black;
    text-style: bold;
}

#btn-run-ocr:focus {
    background: $accent;
    color: black;
    border: solid $accent;
}

HelpScreen > ScrollableContainer {
    border: solid $border;
    padding: 1 2;
    background: $surface;
}

#wizard-title {
    color: $accent;
    text-style: bold;
    padding: 0 2;
    border-bottom: solid $border;
}

#step-indicator {
    color: $secondary;
    padding: 0 2;
    height: 1;
}

#step-prompt {
    color: $text;
    padding: 1 2 0 2;
}

#result-table {
    color: $text;
    padding: 1 2;
}

#result-buttons {
    width: auto;
    height: auto;
    padding: 0 1 1 1;
}

#status-msg {
    color: $text;
    padding: 1 2;
}

#elapsed-label {
    color: $secondary;
    padding: 0 2;
}

#cancel-hint {
    color: $secondary;
    padding: 0 2;
}
