/* Variabili colore — palette CLAUDE.md */
$accent: #E8B84B;
$text: #D4D4D4;
$secondary: #7A7A7A;
$border: #3A3A3A;
$error: #E85B4B;
$success: #4BE87A;
$surface: #1A1A1A;
$surface-soft: #202020;
$surface-accent: #2B2416;

/* Nessun background esplicito — sfondo sempre trasparente */

Screen {
    color: $text;
}

#home-header {
    border: solid $border;
    background: $surface;
    padding: 1 2;
    height: auto;
}

#home-brand {
    color: $accent;
    text-style: bold;
}

#home-subtitle {
    color: $text;
    padding-top: 1;
}

#home-tagline {
    color: $secondary;
}

#header {
    color: $accent;
    border: solid $border;
    background: $surface;
    padding: 1 2;
    height: auto;
    text-style: bold;
}

#footer-bar {
    color: $secondary;
    border-top: solid $border;
    background: $surface;
    padding: 0 2;
    height: auto;
}

ListView {
    background: transparent;
    scrollbar-size: 0 0;
    scrollbar-background: $surface;
    scrollbar-background-hover: $surface;
    scrollbar-background-active: $surface;
    scrollbar-color: $secondary;
    scrollbar-color-hover: $accent;
    scrollbar-color-active: $accent;
    scrollbar-corner-color: $surface;
}

ListView > ListItem {
    color: $text;
    background: $surface-soft;
    border: solid $surface-soft;
    padding: 0 1;
    margin: 0 1 1 1;
    min-height: 3;
}

ListView > ListItem.-highlight {
    background: $surface-soft;
    border: solid $accent;
    color: $text;
}

#body {
    height: 1fr;
    margin-top: 1;
}

#menu-panel {
    width: 34;
    height: 1fr;
    border: solid $border;
    background: $surface;
    padding: 0;
}

#menu-list {
    width: 1fr;
    height: 1fr;
    border: none;
    background: transparent;
    overflow-y: auto;
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
}

#preview-panel {
    width: 1fr;
    height: 1fr;
    border: solid $border;
    background: $surface;
    padding: 0;
}

#preview-copy {
    height: 1fr;
    overflow-y: auto;
    scrollbar-gutter: stable;
    scrollbar-size: 1 1;
    scrollbar-background: $surface;
    scrollbar-background-hover: $surface;
    scrollbar-background-active: $surface-soft;
    scrollbar-color: $border;
    scrollbar-color-hover: $accent;
    scrollbar-color-active: $accent;
    scrollbar-corner-color: $surface;
}

.panel-title {
    color: $accent;
    text-style: bold;
    background: $surface-soft;
    border-bottom: solid $border;
    padding: 0 1;
    height: auto;
}

.menu-item-title {
    color: $text;
    text-style: bold;
}

.menu-item-summary {
    color: $secondary;
}

ListView > ListItem.-highlight .menu-item-title {
    color: $accent;
}

ListView > ListItem.-highlight .menu-item-summary {
    color: $text;
}

#preview-title {
    color: $accent;
    text-style: bold;
    padding: 1 1 0 1;
}

#preview-body {
    color: $text;
    height: 1fr;
    padding: 1 1 0 1;
    text-wrap: wrap;
}

#preview-hint {
    color: $secondary;
    border-top: solid $border;
    background: $surface-soft;
    padding: 1 1 0 1;
}

.error-label {
    color: $error;
    padding: 0 2;
    height: 1;
}

.success-label {
    color: $success;
}

ProgressBar Bar {
    color: $accent;
    background: $border;
}

Button {
    border: solid $surface-soft;
    background: $surface-soft;
    color: $text;
    margin: 1 1 0 1;
    width: auto;
}

Button:focus {
    text-style: bold;
    color: $accent;
    border: solid $accent;
    border-top: solid $accent;
    border-bottom: solid $accent;
    background: $surface-soft;
    background-tint: 0%;
}

#btn-run-ocr {
    text-style: bold;
}

/* In Textual il focus dei Button default applica anche reverse + background-tint.
   Qui li neutralizziamo nel blocco risultato con specificità più alta. */
#result-buttons Button:focus {
    text-style: bold;
    background: $surface-soft;
    background-tint: 0%;
    color: $accent;
    border: solid $accent;
    border-top: solid $accent;
    border-bottom: solid $accent;
}

HelpScreen > ScrollableContainer {
    border: solid $border;
    padding: 1 2;
    background: $surface;
    overflow-y: auto;
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
}

#wizard-title {
    color: $accent;
    text-style: bold;
    padding: 0 2;
    border-bottom: solid $border;
}

#step-indicator {
    color: $secondary;
    padding: 0 2;
    height: 1;
}

#step-prompt {
    color: $text;
    padding: 1 2 0 2;
}

#ocr-menu-panel {
    border: solid $border;
    background: $surface;
    height: 1fr;
}

#ocr-menu-panel #menu-list {
    height: auto;
    max-height: 12;
    border-bottom: solid $border;
    padding-top: 1;
}

#ocr-menu-preview {
    height: 1fr;
    background: $surface;
}

#ocr-preview-title {
    color: $accent;
    text-style: bold;
    padding: 1 2 0 2;
}

#ocr-preview-body {
    color: $text;
    padding: 1 2;
    text-wrap: wrap;
}

#ocr-preview-hint {
    color: $secondary;
    border-top: solid $border;
    background: $surface-soft;
    padding: 0 2;
    height: auto;
}

#step-input {
    margin: 0 2;
}

#finder-button,
#check-picker-button {
    margin: 1 2 0 2;
    width: auto;
}

Input {
    background: $surface-soft;
    color: $text;
    border: solid $border;
    padding: 0 1;
    height: 3;
    scrollbar-size-horizontal: 0;
    scrollbar-size-vertical: 0;
}

Input:focus {
    background: $surface-soft;
    border: solid $accent;
}

#step-choices {
    margin: 0 2;
    border: solid $border;
    background: $surface;
    height: auto;
    max-height: 12;
}

#step-choices > ListItem {
    min-height: 2;
}

#step-hint,
#check-hint {
    color: $secondary;
    padding: 0 2;
    height: auto;
}

#result-table {
    color: $text;
    padding: 1 2;
}

#result-buttons {
    width: auto;
    height: auto;
    padding: 0 1 1 1;
}

#status-msg {
    color: $text;
    padding: 1 2;
}

#progress-bar {
    width: 100%;
    margin: 0 2 1 2;
}

#progress-result-buttons,
#system-check-buttons {
    width: auto;
    height: auto;
    padding: 0 1 1 1;
}

#system-check-container {
    border: solid $border;
    padding: 1 2;
    background: $surface;
    overflow-y: auto;
    scrollbar-size-vertical: 0;
    scrollbar-size-horizontal: 0;
}

#system-check-content {
    color: $text;
}
